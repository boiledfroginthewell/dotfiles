#!/usr/bin/env bash
set -eu -o pipefail

if [[ "${1:-}" = -i ]]; then
	echo "Warning: dropped iconify support" >&2
fi

get_project_root() {
	if [ -n "$1" ]; then
		cd "$1"
	fi
	local PROJECT_ROOT
	PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)/"
	echo "${PROJECT_ROOT:-$PWD}"
}

directory="${1:-}"
projectRoot=$(get_project_root "${directory}")
if [ -z "$directory" ]; then
	directory="$projectRoot"
fi

if type grealpath >&/dev/null; then
	_REALPATH=grealpath
else
	_REALPATH=realpath
fi
relativeProjectRoot="$($_REALPATH --relative-to="$PWD" "$projectRoot" 2>/dev/null)/"
# If realpath fails, fallback to simple logic
if [ -z "$relativeProjectRoot" ]; then
	relativeProjectRoot=${projectRoot#"$PWD"/}
	relativeProjectRoot=${relativeProjectRoot:-.}
fi


cat \
	<(fd .) \
	<(test -n "${directory}" && test "$directory" != "PWD" && fd . "${directory}" --exclude="${PWD}") \
	<(jumper find | sed 's;$;/;') | \
sed -E \
	-e "s:^$PWD/::" \
	-e "s:^$projectRoot:$relativeProjectRoot:" \
	-e "s:^$HOME/:~/:" |\
awk '!x[$0]++'
