#!/usr/bin/env bash
set -eu -o pipefail

while IFS= read -r line; do
	emoji="гАА"
	if [[ "$line" == *.sh ]]; then
		emoji="рЯРЪ"
	elif [[ "$line" == *.fish ]]; then
		emoji="рЯРЯ"
	elif [[ "$line" == *.lua ]]; then
		emoji="у∞Ґ±"
	elif [[ "$line" == *.vim ]]; then
		emoji="оЯЕ"
	elif [[ "$line" == *.py ]]; then
		emoji="оШЖ"
	elif [[ "$line" =~ \.(js|ts)$ ]]; then
		emoji="оШМ"
	elif [[ "$line" == *.java ]]; then
		emoji="вШХ"
	elif [[ "$line" == *.cql ]]; then
		emoji="рЯСБпЄП"
	elif [[ "$line" =~ \.[shc]ql$ ]]; then
		emoji="рЯЫҐпЄП"
	elif [[ "$line" =~ \.(txt|md)$ ]] || [[ "$line" == *"README" ]]; then
		emoji="рЯУЭ"
	elif [[ "$line" == *.json ]]; then
		# emji пђ•
		emoji="ођП"
	elif [[ "$line" == *.xml ]]; then
		# emoji пЬ≠
		emoji="у∞ЧА"
	elif [[ "$line" =~ \.ya?ml$ ]]; then
		emoji="вЪЩпЄП"
	elif [[ "$line" == *.toml ]]; then
		emoji="вЪЩпЄП"
	elif [[ "$line" =~ .*\.env(\.|$) ]]; then
		emoji="вЪЩпЄП"
	elif [[ "$line" == *.ini ]] || [[ "$line" == *.properties ]]; then
		emoji="вЪЩпЄП"
	elif [[ "$line" =~ \.(exe|ps1)$ ]]; then
		emoji="оЬП"
	elif [[ "$line" =~ \.[ct]sv$ ]]; then
		emoji="пГО"
	elif [[ "$line" =~ \.tf$ ]]; then
		emoji="у±БҐ"
	elif [[ "$line" =~ \.(key|pem)$ ]]; then
		emoji="рЯФС"
	elif [[ "$line" =~ git ]]; then
		# emoji "оЬИ"
		emoji="пДУ"
	elif [[ "$line" =~ [Dd][Oo][Cc][Kk][Ee][Rr] ]]; then
		emoji="рЯРЛ"
	elif [[ "$line" =~ [Aa][Ww][Ss] ]]; then
		emoji="пЙ∞"
	elif [[ "$line" == *.lock ]]; then
		emoji="о©µ"
	elif [[ "$line" == */opt/* ]]; then
		emoji="рЯ§Ц"
	elif [[ "$line" =~ /(\.?config|dotfiles) ]]; then
		emoji="вЪЩпЄП"
	elif [[ "$line" == */ ]]; then
		emoji="рЯУБ"
	fi
	echo "$emoji $line"
done
