#!/usr/bin/env bash
set -eu -o pipefail

while IFS= read -r line; do
	emoji="гАА"
	if [[ "$line" == *.sh ]]; then
		emoji="рЯРЪ"
	elif [[ "$line" == *.fish ]]; then
		emoji="рЯРЯ"
	elif [[ "$line" == *.lua ]]; then
		emoji="у∞Ґ±"
	elif [[ "$line" == *.vim ]]; then
		emoji="оЯЕ"
	elif [[ "$line" == *.py ]]; then
		emoji="оШЖ"
	elif [[ "$line" =~ \.(js|ts)$ ]]; then
		emoji="оШМ"
	elif [[ "$line" == *.java ]]; then
		emoji="вШХ"
	elif [[ "$line" == *.cql ]]; then
		emoji="рЯСБпЄП"
	elif [[ "$line" =~ \.[shc]ql$ ]]; then
		emoji="рЯЫҐпЄП"
	elif [[ "$line" =~ \.(txt|md)$ ]] || [[ "$line" == *"README" ]]; then
		emoji="рЯУЭ"
	elif [[ "$line" == *.json ]]; then
		# emji пђ•
		emoji="ођП"
	elif [[ "$line" == *.xml ]]; then
		# emoji пЬ≠
		emoji="у∞ЧА"
	elif [[ "$line" =~ \.(ya?ml|toml|ini|properties|conf)$ ]]; then
		emoji="вЪЩпЄП"
	elif [[ "$line" =~ .*\.env(\.|$) ]]; then
		emoji="вЪЩпЄП"
	elif [[ "$line" =~ \.(exe|ps1|bat)$ ]]; then
		emoji="оЬП"
	elif [[ "$line" =~ \.[ct]sv$ ]]; then
		emoji="пГО"
	elif [[ "$line" =~ \.tf$ ]]; then
		emoji="у±БҐ"
	elif [[ "$line" =~ \.(key|pem)$ ]]; then
		emoji="рЯФС"
	elif [[ "$line" =~ \.(png|jpg|gif)$ ]]; then
		emoji="пАЊ"
	elif [[ "$line" =~ \.(pu)$ ]]; then
		emoji="оГС"
	elif [[ "$line" == *.groovy ]]; then
		emoji="у∞І≠"
	elif [[ "$line" =~ \.(gradle)$|gradlew$ ]]; then
		emoji="оЩ†"
	elif [[ "$line" =~ git ]]; then
		# emoji "оЬИ"
		emoji="пДУ"
	elif [[ "$line" =~ [Dd][Oo][Cc][Kk][Ee][Rr] ]]; then
		emoji="рЯРЛ"
	elif [[ "$line" =~ [Aa][Ww][Ss] ]]; then
		emoji="пЙ∞"
	elif [[ "$line" == *.lock ]]; then
		emoji="о©µ"
	elif [[ "$line" == */opt/* ]]; then
		emoji="рЯ§Ц"
	elif [[ "$line" =~ /(\.?config|dotfiles) ]]; then
		emoji="вЪЩпЄП"
	elif [[ "$line" == */ ]]; then
		emoji="пРУ"
	fi
	echo "$emoji $line"
done
